AZURE_SUBSCRIPTION_ID=
AZURE_SUBSCRIPTION_NAME=
AZURE_RESOURCE_GROUP=

AZURE_SEARCH_SERVICE_ENDPOINT=
AZURE_SEARCH_INDEX_NAME=
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_DATASOURCE_NAME=

AZURE_STORAGE_CONNECTION_STRING=

EMBEDDING_ENGINE=text-embedding-ada-002
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
GPT_ENGINE=gpt-4o

AZURE_BLOB_SAS_TOKEN=
BLOB_SAS_URL=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_BLOB_CONTAINER_NAME=
AZURE_STORAGE_ACCOUNT_KEY=

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Azure Cosmos DB (NoSQL API)
# Leave COSMOS_ENDPOINT and COSMOS_KEY blank to use the local file-backed
# state service. Set both to switch to the real Cosmos backend.
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=docmind

# Azure AD (Entra ID) — used to validate JWT tokens on the API
AZURE_TENANT_ID=
AZURE_API_CLIENT_ID=
AZURE_API_AUDIENCE=

# Local dev — disable JWT auth when true
DOCMIND_DISABLE_AUTH=true

# Redis (chat memory)
# Local docker-compose default: redis://redis:6379/0
# Azure Cache for Redis: rediss://:<access-key>@<name>.redis.cache.windows.net:6380/0
REDIS_URL=
REDIS_PREFIX=docmind